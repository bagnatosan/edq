@{
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString();
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no"/>
    <title>@ViewData["Title"] - edq.</title>
    <link rel="manifest" href="/manifest.json"/>
    <meta name="theme-color" content="#39ff14"/>
    <meta name="apple-mobile-web-app-capable" content="yes"/>
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent"/>
    <meta name="apple-mobile-web-app-title" content="EDQ"/>
    <link rel="icon" type="image/svg+xml" href="~/favicon.svg" asp-append-version="true"/>
    <link rel="apple-touch-icon" href="/images/logo_appicon.svg"/>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true"/>
    <meta name="mobile-web-app-capable" content="yes">
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    <!-- Banner de "sin conexión": se muestra automáticamente cuando el navegador pierde la red -->
    <!-- Aparece justo debajo del header fijo (top: 68px = altura del .app-header) -->
    <div id="offline-banner" style="
        display: none;
        position: fixed;
        top: 68px; left: 0; right: 0;
        z-index: 9;
        background: rgba(200, 40, 40, 0.95);
        backdrop-filter: blur(8px);
        color: #fff;
        font-family: 'Inter', sans-serif;
        font-size: 13px;
        font-weight: 600;
        padding: 9px 16px;
        text-align: center;
        letter-spacing: 0.2px;
        border-bottom: 1px solid rgba(255, 120, 120, 0.4);
        box-shadow: 0 4px 16px rgba(0,0,0,0.35);
        animation: offline-slide-down 0.3s ease;
    ">
        📵 Sin conexión — los cambios no se guardarán hasta que vuelva la red
    </div>
    <style>
        @@keyframes offline-slide-down {
            from { transform: translateY(-100%); opacity: 0; }
            to   { transform: translateY(0);     opacity: 1; }
        }
        @@keyframes offline-slide-up {
            from { transform: translateY(0);     opacity: 1; }
            to   { transform: translateY(-100%); opacity: 0; }
        }
    </style>

    <!-- Contenedor móvil centralizado (App Shell) -->
    <div class="app-shell">
        
        <!-- Header superior fijo -->
        <header class="app-header">
            <div class="app-header-left">
                <!-- Logotipo del Navbar cargado directamente -->
                <a href="/" style="display: flex; align-items: center; text-decoration: none;">
                    <img src="~/images/logo_navbar.svg" alt="edq." class="navbar-logo" />
                </a>
            </div>

            @if (User.Identity?.IsAuthenticated == true)
            {
                <div class="app-header-right">
                    <nav class="desktop-nav">
                        <a href="/Group/Explore" class="@(currentController == "Group" && currentAction == "Explore" ? "active" : "")" aria-label="Home">
                            <svg viewBox="0 0 24 24" width="22" height="22" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" fill="none">
                                <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z" />
                                <polyline points="9 22 9 12 15 12 15 22" />
                            </svg>
                        </a>
                        <a href="/Match/Upcoming" class="@(currentController == "Match" && currentAction == "Upcoming" ? "active" : "")" aria-label="Partidos">
                            <svg viewBox="0 0 24 24" width="22" height="22" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" fill="none">
                                <rect x="2" y="4" width="20" height="16" rx="2" />
                                <line x1="12" y1="4" x2="12" y2="20" />
                                <circle cx="12" cy="12" r="3.5" />
                            </svg>
                        </a>
                        <a href="/Group/Chat" class="@(currentController == "Chat" ? "active" : "")" aria-label="Chat">
                            <svg viewBox="0 0 24 24" width="22" height="22" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" fill="none">
                                <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z" />
                            </svg>
                        </a>
                        <a href="/Account/Profile" class="@(currentController == "Account" && currentAction == "Profile" ? "active" : "")" aria-label="Perfil">
                            <svg viewBox="0 0 24 24" width="22" height="22" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" fill="none">
                                <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" />
                                <circle cx="12" cy="7" r="4" />
                            </svg>
                        </a>
                    </nav>

                    <!-- Icono de Campana para notificaciones con menú desplegable -->
                    <div class="notifications-menu-container">
                        <button class="header-icon-btn" id="btnNotificationsToggle" aria-label="Notificaciones">
                            <svg viewBox="0 0 24 24">
                                <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9M13.73 21a2 2 0 0 1-3.46 0" stroke-linecap="round" stroke-linejoin="round"/>
                            </svg>
                            <span class="notification-badge" id="notificationBadge" style="display: none;">0</span>
                        </button>
                        <div class="notifications-dropdown" id="notificationsDropdown">
                            <div class="notifications-dropdown-header">
                                <span>Notificaciones</span>
                                <button class="btn-clear-notifications" id="btnClearNotifications">Limpiar todo</button>
                            </div>
                            <div class="notifications-dropdown-list" id="notificationsDropdownList">
                                <div class="notifications-empty">No tienes notificaciones</div>
                            </div>
                        </div>
                    </div>
                </div>
            }
            
        </header>

        <!-- Contenedor principal scrollable para las vistas -->
        <main class="app-content @(User.Identity?.IsAuthenticated == true ? "with-nav" : "")" role="main">
            @RenderBody()

            <footer class="app-footer-desktop">
                <span>&copy; @DateTime.Now.Year edq. Todos los derechos reservados.</span>
            </footer>
        </main>

        @if (User.Identity?.IsAuthenticated == true)
        {
            <!-- Barra de navegación inferior fija (Solo si está logueado) -->
            <nav class="app-nav">
                <a href="/Group/Explore" class="nav-item @(currentController == "Group" && currentAction == "Explore" ? "active" : "")">
                    <svg viewBox="0 0 24 24">
                        <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z" stroke-linecap="round" stroke-linejoin="round"/>
                        <polyline points="9 22 9 12 15 12 15 22" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                    <span>Home</span>
                </a>
                
                <a href="/Match/Upcoming" class="nav-item @(currentController == "Match" && currentAction == "Upcoming" ? "active" : "")">
                    <svg viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" fill="none">
                        <rect x="2" y="4" width="20" height="16" rx="2" />
                        <line x1="12" y1="4" x2="12" y2="20" />
                        <circle cx="12" cy="12" r="3.5" />
                    </svg>
                    <span>Partidos</span>
                </a>
                
                <a href="/Group/Chat" class="nav-item @(currentController == "Chat" ? "active" : "")">
                    <svg viewBox="0 0 24 24">
                        <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                    <span>Chat</span>
                </a>
                
                <a href="/Account/Profile" class="nav-item @(currentController == "Account" && currentAction == "Profile" ? "active" : "")">
                    <svg viewBox="0 0 24 24">
                        <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" stroke-linecap="round" stroke-linejoin="round"/>
                        <circle cx="12" cy="7" r="4" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                    <span>Perfil</span>
                </a>
            </nav>
        }
    </div>

    <script src="~/js/push-notifications.js" asp-append-version="true"></script>
    <script>
        if ('serviceWorker' in navigator) {
            window.addEventListener('load', () => {
                navigator.serviceWorker.register('/sw.js')
                    .then(reg => console.log('Service Worker registered successfully:', reg.scope))
                    .catch(err => console.error('Service Worker registration failed:', err));
            });
        }
    </script>
    @await RenderSectionAsync("Scripts", required: false)
    <script>
        // Animación de salida al navegar (fallback para Firefox y navegadores sin @@view-transition)
        // Chrome y Edge usan la View Transitions API nativa del CSS, no necesitan esto.
        if (!document.startViewTransition) {
            document.addEventListener('click', function(e) {
                var link = e.target.closest('a[href]');
                // Ignorar links sin destino, externos, anclas o que abren nueva pestaña
                if (!link || !link.href || link.target === '_blank' ||
                    link.href.startsWith('javascript:') || link.href === '#' ||
                    link.href.startsWith('mailto:') || link.href.startsWith('tel:') ||
                    link.href === window.location.href)
                    return;

                e.preventDefault();
                var dest = link.href;
                // Aplica el fade-out (200ms) y luego navega
                document.documentElement.style.transition = 'opacity 0.2s ease';
                document.documentElement.style.opacity = '0';
                setTimeout(function() { window.location.assign(dest); }, 200);
            });
        }
    </script>
    <script>
        // Banner de "sin conexión": escucha los eventos offline/online del navegador
        (function() {
            var banner = document.getElementById('offline-banner');
            if (!banner) return;

            function showBanner() {
                banner.style.animation = 'offline-slide-down 0.3s ease';
                banner.style.display = 'block';
            }

            function hideBanner() {
                banner.style.animation = 'offline-slide-up 0.3s ease';
                // Esperar a que termine la animación antes de ocultar
                setTimeout(function() { banner.style.display = 'none'; }, 280);
            }

            // Si ya arrancó sin conexión, mostrar inmediatamente
            if (!navigator.onLine) showBanner();

            window.addEventListener('offline', showBanner);
            window.addEventListener('online',  hideBanner);
        })();
    </script>
</body>
</html>