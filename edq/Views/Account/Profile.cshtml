@model edq.Models.Player
@{
    ViewData["Title"] = "Perfil";
}

<div class="profile-container">
    <!-- Header/Hero Section -->
    <div class="profile-hero">
        <div class="profile-photo-wrapper">
            <div class="profile-avatar-container" id="profileAvatarContainer">
                @if (!string.IsNullOrEmpty(Model.PhotoUrl))
                {
                    <img src="@Model.PhotoUrl" alt="Foto de perfil" class="profile-avatar-img" id="profileAvatarImg" />
                }
                else
                {
                    <div class="profile-avatar-initials" id="profileAvatarInitials">@Model.Initials</div>
                }
            </div>
            
            <!-- Botón del lápiz verde flotante -->
            <button class="profile-photo-edit-btn" id="btnEditPhoto" aria-label="Modificar foto de perfil">
                <svg viewBox="0 0 24 24" width="18" height="18">
                    <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
                    <path d="M18.5 2.5a2.121 2.121 0 1 1 3 3L12 15l-4 1 1-4 9.5-9.5z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
                </svg>
            </button>
            <input type="file" id="filePhotoInput" accept="image/*" style="display: none;" />
        </div>
        
        <h2 class="profile-name">@Model.Name @Model.LastName</h2>
        @if (!string.IsNullOrEmpty(Model.Nickname))
        {
            <p class="profile-nickname-badge">@@<span id="txtNickname">@Model.Nickname</span></p>
        }
        else
        {
            <p class="profile-nickname-badge text-muted">@@<span id="txtNickname">sin_apodo</span></p>
        }
    </div>

    <!-- Options List -->
    <div class="profile-options-list">
        <!-- Modificar apodo -->
        <button class="profile-option-item" id="btnModificarApodo">
            <div class="option-left">
                <svg class="option-icon" viewBox="0 0 24 24">
                    <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" stroke="currentColor" stroke-linecap="round" fill="none"/>
                    <circle cx="12" cy="7" r="4" stroke="currentColor" stroke-linecap="round" fill="none"/>
                </svg>
                <span>Modificar apodo</span>
            </div>
            <svg class="option-arrow" viewBox="0 0 24 24">
                <polyline points="9 18 15 12 9 6" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
            </svg>
        </button>

        <!-- Ajustes de notificaciones -->
        <button class="profile-option-item" id="btnConfigurarNotificaciones" style="display: none;">
            <div class="option-left">
                <svg class="option-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="12" cy="12" r="3"/>
                    <path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 1 1-2.83-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 1 1 2.83-2.83l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 1 1 2.83 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z"/>
                </svg>
                <span>Ajustes de notificaciones</span>
            </div>
            <svg class="option-arrow" viewBox="0 0 24 24">
                <polyline points="9 18 15 12 9 6" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
            </svg>
        </button>

        <!-- Administrar notificaciones -->
        <div class="profile-option-item option-non-clickable">
            <div class="option-left">
                <svg class="option-icon" viewBox="0 0 24 24">
                    <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9M13.73 21a2 2 0 0 1-3.46 0" stroke="currentColor" stroke-linejoin="round" fill="none"/>
                </svg>
                <span>Activar notificaciones</span>
            </div>
            <!-- Switch Toggle Switch Premium -->
            <label class="switch-premium">
                <input type="checkbox" id="switchNotifications" />
                <span class="switch-slider"></span>
            </label>
        </div>
    </div>

    <!-- Cerrar sesión -->
    <div class="profile-logout-container">
        <form asp-controller="Account" asp-action="Logout" method="post" id="formLogout">
            <button type="submit" class="btn-logout">
                <svg class="logout-icon" viewBox="0 0 24 24">
                    <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
                    <polyline points="16 17 21 12 16 7" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
                    <line x1="21" y1="12" x2="9" y2="12" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                Cerrar sesión
            </button>
        </form>
        
        <button type="button" class="btn-logout" id="btnDeleteAccount" style="margin-top: 12px; background: transparent; border: 1px solid rgba(255, 56, 56, 0.3); color: #ff3838;">
            <svg class="logout-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="3 6 5 6 21 6"></polyline>
                <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path>
                <line x1="10" y1="11" x2="10" y2="17"></line>
                <line x1="14" y1="11" x2="14" y2="17"></line>
            </svg>
            Eliminar cuenta
        </button>
    </div>
</div>

<!-- Modal para Modificar Apodo -->
<div class="modal-backdrop" id="modalApodoBackdrop">
    <div class="modal-card">
        <h3 class="modal-card-title">Modificar Apodo</h3>
        <p class="modal-card-desc">Ingresá tu nuevo apodo para mostrar en la aplicación.</p>
        
        <div class="form-group">
            <input type="text" id="inputNickname" class="form-control-neon" placeholder="Tu apodo" value="@Model.Nickname" maxlength="20" />
            <span class="input-error-msg" id="errorApodo"></span>
        </div>
        
        <div class="modal-actions">
            <button class="btn-modal-cancel" id="btnCancelApodo">Cancelar</button>
            <button class="btn-modal-save" id="btnSaveApodo">Guardar</button>
        </div>
    </div>
</div>

<!-- Modal para Configuración de Notificaciones -->
<div class="modal-backdrop" id="modalConfigNotificacionesBackdrop">
    <div class="modal-card">
        <h3 class="modal-card-title">Configuración de Notificaciones</h3>
        <p class="modal-card-desc">Elegí qué notificaciones querés recibir en tu dispositivo.</p>
        
        <div class="notification-settings-list">
            <!-- Creación de partidos -->
            <div class="notification-setting-row">
                <div class="setting-info">
                    <span class="setting-title">Creación de partidos</span>
                    <span class="setting-desc">Notificar cuando se crea un partido y estoy convocado.</span>
                </div>
                <label class="switch-premium">
                    <input type="checkbox" id="chkNotifyMatchCreation" @(Model.NotifyMatchCreation ? "checked" : "") />
                    <span class="switch-slider"></span>
                </label>
            </div>
            
            <!-- Modificación de partidos -->
            <div class="notification-setting-row">
                <div class="setting-info">
                    <span class="setting-title">Modificación de partidos</span>
                    <span class="setting-desc">Notificar cuando cambie un partido en el que estoy convocado.</span>
                </div>
                <label class="switch-premium">
                    <input type="checkbox" id="chkNotifyMatchModification" @(Model.NotifyMatchModification ? "checked" : "") />
                    <span class="switch-slider"></span>
                </label>
            </div>
            
            <!-- Chat y Encuestas -->
            <div class="notification-setting-row">
                <div class="setting-info">
                    <span class="setting-title">Chat y Encuestas</span>
                    <span class="setting-desc">Notificar mensajes nuevos y encuestas creadas en los grupos.</span>
                </div>
                <label class="switch-premium">
                    <input type="checkbox" id="chkNotifyChat" @(Model.NotifyChat ? "checked" : "") />
                    <span class="switch-slider"></span>
                </label>
            </div>
        </div>
        
        <div class="modal-actions" style="margin-top: 24px;">
            <button class="btn-modal-cancel" id="btnCancelConfigNotificaciones">Cancelar</button>
            <button class="btn-modal-save" id="btnSaveConfigNotificaciones">Guardar</button>
        </div>
    </div>
</div>

<!-- Modal para Confirmar Eliminación de Cuenta (Estilo GitHub) -->
<div class="modal-backdrop" id="modalDeleteAccountBackdrop">
    <div class="modal-card" style="border-color: rgba(255, 56, 56, 0.4);">
        <h3 class="modal-card-title" style="color: #ff3838; display: flex; align-items: center; gap: 8px;">
            <svg viewBox="0 0 24 24" width="20" height="20" stroke="currentColor" stroke-width="2.5" fill="none" stroke-linecap="round" stroke-linejoin="round">
                <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"></path>
                <line x1="12" y1="9" x2="12" y2="13"></line>
                <line x1="12" y1="17" x2="12.01" y2="17"></line>
            </svg>
            ¿Estás completamente seguro?
        </h3>
        <p class="modal-card-desc" style="color: var(--text-secondary); margin-bottom: 16px;">
            Esta acción es <strong>permanente e irreversible</strong>. Se eliminará tu perfil, historial de partidos, mensajes de chat y tu posición en el ranking de forma definitiva.
        </p>
        
        <div class="form-group" style="margin-bottom: 16px;">
            <label class="form-label" style="font-size: 12px; color: var(--text-muted); margin-bottom: 8px; display: block;">
                Escribí <strong>quiero eliminar mi cuenta</strong> para confirmar:
            </label>
            <input type="text" id="confirmDeleteInput" class="form-control-neon" style="border-color: rgba(255, 56, 56, 0.2); text-align: center;" placeholder="Escribir aquí" autocomplete="off" />
        </div>
        
        <div class="modal-actions">
            <button class="btn-modal-cancel" id="btnCancelDeleteAccount" style="flex: 1;">Cancelar</button>
            <button class="btn-modal-save" id="btnConfirmDeleteAccount" style="flex: 1; background: #ff3838; color: #fff; opacity: 0.5;" disabled>Eliminar permanentemente</button>
        </div>
    </div>
</div>


@section Scripts {
    <script src="~/js/profile.js" asp-append-version="true"></script>
}
