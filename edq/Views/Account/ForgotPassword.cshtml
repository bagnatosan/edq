@{
    ViewData["Title"] = "Recuperar Contraseña";
}

<div class="hero-container auth-hero">
    <img src="/images/logo_appicon.svg" alt="edq. Logo" class="logo-hero auth-logo" />
    <h1 class="hero-title auth-title">Recuperar Acceso</h1>
</div>

<div class="card">
    <div class="auth-wrapper">
        <div class="auth-form" style="opacity: 1; transform: none; pointer-events: all; position: relative; width: 100%;">
            <h2 class="card-title auth-card-title">¿Olvidaste tu contraseña?</h2>
            <p style="color: var(--text-secondary); font-size: 13px; margin-bottom: 20px; text-align: center; line-height: 1.5;">
                Ingresá tu correo electrónico registrado y te enviaremos un código de recuperación.
            </p>

            <form method="post" asp-controller="Account" asp-action="ForgotPassword">
                @if (!ViewData.ModelState.IsValid)
                {
                    <div class="auth-error-container">
                        @foreach (var modelState in ViewData.ModelState.Values)
                        {
                            foreach (var error in modelState.Errors)
                            {
                                <div class="auth-error-message">
                                    <span class="error-icon">⚠️</span> @error.ErrorMessage
                                </div>
                            }
                        }
                    </div>
                }

                <div class="form-group" style="margin-bottom: 20px;">
                    <label class="form-label">Email</label>
                    <input type="email" name="Email" class="form-control-neon" maxlength="50" required />
                </div>

                <button type="submit" class="btn-neon" style="margin-top: 10px; position: relative;"><span class="btn-text">Enviar Código</span></button>
            </form>

            <div class="form-footer-link">
                ¿Te acordaste? <a href="/Account/Login">Volver al ingreso</a>
            </div>
        </div>
    </div>
</div>



@section Scripts {
    <script src="~/js/forgot-password.js" asp-append-version="true"></script>
}
