@{
    ViewData["Title"] = "Verificar Código";
}

<div class="hero-container auth-hero">
    <img src="/images/logo_appicon.svg" alt="edq. Logo" class="logo-hero auth-logo" />
    <h1 class="hero-title auth-title">Verificar Código</h1>
</div>

<div class="card">
    <div class="auth-wrapper">
        <div class="auth-form" style="opacity: 1; transform: none; pointer-events: all; position: relative; width: 100%;">
            <h2 class="card-title auth-card-title">Código de Recuperación</h2>
            <p style="color: var(--text-secondary); font-size: 13px; margin-bottom: 20px; text-align: center; line-height: 1.5;">
                Ingresá el código de verificación de 4 dígitos (entre 1000 y 9999) que enviamos a la casilla <strong>@ViewBag.Email</strong>.
            </p>

            <form method="post" asp-controller="Account" asp-action="VerifyCode">
                @if (!ViewData.ModelState.IsValid)
                {
                    <div class="auth-error-container">
                        @foreach (var modelState in ViewData.ModelState.Values)
                        {
                            foreach (var error in modelState.Errors)
                            {
                                <div class="auth-error-message">
                                    <span class="error-icon">⚠️</span> @error.ErrorMessage
                                </div>
                            }
                        }
                    </div>
                }

                <div class="form-group" style="margin-bottom: 20px;">
                    <label class="form-label">Código (1000 - 9999)</label>
                    <input type="number" name="Code" class="form-control-neon" min="1000" max="9999" required />
                </div>

                <button type="submit" class="btn-neon" style="margin-top: 10px;">Verificar Código</button>
            </form>

            <div class="form-footer-link">
                ¿No te llegó? <a href="/Account/ForgotPassword">Reenviar correo</a>
            </div>
        </div>
    </div>
</div>
