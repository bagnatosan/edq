@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Cómo instalar EDQ como app en tu iPhone o iPad desde Safari." />
    <title>Instalar EDQ en iOS – Guía paso a paso</title>
    <link rel="icon" href="/images/logo_appicon.svg" type="image/svg+xml" />
    <link rel="stylesheet" href="/css/site.css" />
</head>
<body class="ios-install-body">
    <div class="page">

        <!-- Barra superior con flecha de vuelta -->
        <div class="topbar">
            <a asp-controller="Home" asp-action="Index" class="btn-back" aria-label="Volver atrás">
                <svg viewBox="0 0 24 24"><polyline points="15 18 9 12 15 6"/></svg>
            </a>
        </div>

        <!-- Hero -->
        <div class="hero">
            <div class="hero-logo">
                <img src="/images/logo_appicon.svg" alt="Logo EDQ" />
            </div>
            <div class="hero-text">
                <h1>Instalá <span>EDQ</span> en tu iPhone</h1>
                <p>Seguí estos pasos para agregar la app a tu pantalla de inicio y usarla como si fuera nativa.</p>
            </div>
        </div>

        <!-- Aviso: requiere Safari -->
        <div class="safari-badge">
            <svg width="28" height="28" viewBox="0 0 28 28" fill="none">
                <circle cx="14" cy="14" r="12" stroke="#ff9500" stroke-width="1.5"/>
                <circle cx="14" cy="14" r="1.5" fill="#ff9500"/>
                <polygon points="19,9 14.5,14.5 9,19" fill="#ff9500" opacity=".4"/>
                <polygon points="9,9 13.5,13.5 19,19" fill="#ff9500"/>
            </svg>
            <p><strong>Solo funciona en Safari.</strong> Si abriste este link en Chrome u otro navegador, copiá la URL y pegala en Safari.</p>
        </div>

        <!-- Por qué no está en la App Store -->
        <div class="appstore-note">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#a78bfa" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="10"/>
                <line x1="12" y1="8" x2="12" y2="12"/>
                <line x1="12" y1="16" x2="12.01" y2="16"/>
            </svg>
            <p><strong>¿Por qué no está en la App Store?</strong> Publicar en la App Store tiene un costo anual de u$s 99. EDQ se instala como <em>app web progresiva (PWA)</em> directamente desde Safari, sin pasar por Apple, sin costo extra y con la misma experiencia.</p>
        </div>

        <!-- Pasos -->
        <div class="steps">

            <!-- Paso 1 -->
            <div class="step">
                <div class="step-num">1</div>
                <div class="step-body">
                    <div class="step-title">Abrí en Safari</div>
                    <div class="step-desc">Asegurate de estar usando <strong>Safari</strong>. Es el único navegador de iOS que permite instalar apps web.</div>
                </div>
                <div class="step-icon">
                    <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
                </div>
            </div>

            <!-- Paso 2 -->
            <div class="step">
                <div class="step-num">2</div>
                <div class="step-body">
                    <div class="step-title">Tocá Compartir</div>
                    <div class="step-desc">
                        En la barra inferior de Safari, tocá el botón
                        <span class="icon-pill">
                            <svg viewBox="0 0 24 24"><path d="M4 12v8a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-8"/><polyline points="16 6 12 2 8 6"/><line x1="12" y1="2" x2="12" y2="15"/></svg>
                            Compartir
                        </span>
                    </div>
                </div>
                <div class="step-icon">
                    <svg viewBox="0 0 24 24"><path d="M4 12v8a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-8"/><polyline points="16 6 12 2 8 6"/><line x1="12" y1="2" x2="12" y2="15"/></svg>
                </div>
            </div>

            <!-- Paso 3 -->
            <div class="step">
                <div class="step-num">3</div>
                <div class="step-body">
                    <div class="step-title">Desplazate hacia abajo</div>
                    <div class="step-desc">En el menú que se abre, deslizá hacia abajo hasta encontrar la opción <strong>"Agregar a inicio"</strong>.</div>
                </div>
                <div class="step-icon">
                    <svg viewBox="0 0 24 24"><line x1="12" y1="5" x2="12" y2="19"/><polyline points="19 12 12 19 5 12"/></svg>
                </div>
            </div>

            <!-- Paso 4 -->
            <div class="step">
                <div class="step-num">4</div>
                <div class="step-body">
                    <div class="step-title">Tocá "Agregar a inicio"</div>
                    <div class="step-desc">
                        Tocá
                        <span class="icon-pill">
                            <svg viewBox="0 0 24 24"><rect x="3" y="3" width="18" height="18" rx="4"/><line x1="12" y1="8" x2="12" y2="16"/><line x1="8" y1="12" x2="16" y2="12"/></svg>
                            Agregar a inicio
                        </span>
                        en el listado de opciones.
                    </div>
                </div>
                <div class="step-icon">
                    <svg viewBox="0 0 24 24"><rect x="3" y="3" width="18" height="18" rx="4"/><line x1="12" y1="8" x2="12" y2="16"/><line x1="8" y1="12" x2="16" y2="12"/></svg>
                </div>
            </div>

            <!-- Paso 5 -->
            <div class="step">
                <div class="step-num">5</div>
                <div class="step-body">
                    <div class="step-title">Confirmá el nombre</div>
                    <div class="step-desc">Aparecerá <strong>"EDQ"</strong> como nombre. Tocá <strong>Agregar</strong> en la esquina superior derecha.</div>
                </div>
                <div class="step-icon">
                    <svg viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg>
                </div>
            </div>

        </div>

        <!-- Card final -->
        <div class="done-card">
            <div class="emoji">🎉</div>
            <h2>¡Listo! Ya tenés EDQ en tu inicio</h2>
            <p>La app aparece en tu pantalla de inicio como si fuera nativa. Tocala para abrirla sin barras de Safari, en pantalla completa.</p>
        </div>

    </div>
</body>
</html>
