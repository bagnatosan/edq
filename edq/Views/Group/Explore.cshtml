@{
    ViewData["Title"] = "Explorador de Grupos";
}

@Html.AntiForgeryToken()

<!-- Encabezado de la Vista -->
<div class="hero-container auth-hero" style="padding-top: 10px; padding-bottom: 10px;">
    <h1 class="hero-title" style="font-size: 24px; margin-bottom: 4px;">Explorar Grupos</h1>
    <p style="color: var(--text-secondary); font-size: 14px;">Buscador global de grupos disponibles</p>
</div>

<!-- Buscador en tiempo real -->
<div class="search-container">
    <div class="search-input-wrapper">
        <svg class="search-icon" viewBox="0 0 24 24">
            <circle cx="11" cy="11" r="8"></circle>
            <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
        </svg>
        <input type="text" id="searchInput" class="form-control-neon" placeholder="Buscar grupo por nombre..." autocomplete="off" />
    </div>
</div>

<!-- Listado de Grupos -->
<div id="groupsList" class="groups-list">
    <!-- Cargado dinámicamente -->
</div>

<!-- Indicadores de Carga y Mensajes -->
<div class="load-more-container">
    <button id="btnLoadMore" class="btn-outline-neon" style="display: none; padding: 10px 20px; font-size: 14px; width: auto;">Cargar más</button>
    <div id="loadingIndicator" class="loading-spinner" style="display: none;">Cargando grupos...</div>
    <div id="noResultsMessage" class="no-results-message" style="display: none;">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="10"></circle>
            <line x1="8" y1="12" x2="16" y2="12"></line>
        </svg>
        <span>No se encontraron grupos disponibles.</span>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", () => {
            const searchInput = document.getElementById("searchInput");
            const groupsList = document.getElementById("groupsList");
            const btnLoadMore = document.getElementById("btnLoadMore");
            const loadingIndicator = document.getElementById("loadingIndicator");
            const noResultsMessage = document.getElementById("noResultsMessage");

            let currentSearch = "";
            let skip = 0;
            const take = 15;
            let isLoading = false;
            let hasMore = true;
            let searchTimeout = null;

            // Cargar grupos desde la API
            const loadGroups = async (append = true) => {
                if (isLoading) return;
                isLoading = true;
                
                // Mostrar spinner y ocultar botón / sin resultados
                loadingIndicator.style.display = "flex";
                btnLoadMore.style.display = "none";
                noResultsMessage.style.display = "none";

                try {
                    const response = await fetch(`/Group/GetGroups?search=${encodeURIComponent(currentSearch)}&skip=${skip}&take=${take}`);
                    if (!response.ok) throw new Error("Error en la carga de grupos.");

                    const groups = await response.json();

                    if (!append) {
                        groupsList.innerHTML = "";
                    }

                    if (groups.length === 0 && skip === 0) {
                        noResultsMessage.style.display = "flex";
                        hasMore = false;
                    } else {
                        groups.forEach(group => {
                            const card = createGroupCard(group);
                            groupsList.appendChild(card);
                        });

                        // Determinar si hay más elementos
                        if (groups.length < take) {
                            hasMore = false;
                            btnLoadMore.style.display = "none";
                        } else {
                            hasMore = true;
                            btnLoadMore.style.display = "block";
                        }
                    }

                    skip += groups.length;

                } catch (error) {
                    console.error("Error cargando grupos:", error);
                    alert("Ocurrió un error al cargar los grupos.");
                } finally {
                    isLoading = false;
                    loadingIndicator.style.display = "none";
                }
            };

            // Crear la tarjeta de grupo individual
            const createGroupCard = (group) => {
                const card = document.createElement("div");
                card.className = "group-card";
                card.dataset.groupId = group.id;

                // Crear estructura de la tarjeta
                card.innerHTML = `
                    <div class="group-card-header">
                        <div class="group-card-title">${escapeHtml(group.name)}</div>
                        <div class="group-card-creator">
                            👤 Creador: ${escapeHtml(group.creatorName)}
                        </div>
                    </div>
                    <div class="group-card-meta">
                        <div class="meta-item">
                            <svg viewBox="0 0 24 24">
                                <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path>
                                <circle cx="9" cy="7" r="4"></circle>
                                <path d="M23 21v-2a4 4 0 0 0-3-3.87"></path>
                                <path d="M16 3.13a4 4 0 0 1 0 7.75"></path>
                            </svg>
                            <span>${group.memberCount} ${group.memberCount === 1 ? 'miembro' : 'miembros'}</span>
                        </div>
                    </div>
                    <div class="group-card-action">
                        ${renderAction(group)}
                    </div>
                `;

                // Añadir evento al botón de unirse si existe
                const joinBtn = card.querySelector(".btn-join-group");
                if (joinBtn) {
                    joinBtn.addEventListener("click", () => handleJoinRequest(group.id, joinBtn));
                }

                return card;
            };

            // Renderizar el botón o badge según el estado
            const renderAction = (group) => {
                if (group.isCreator) {
                    return `<span class="badge-status badge-status-creator">👑 Administrador (Tuyo)</span>`;
                }
                if (group.isMember) {
                    return `<span class="badge-status badge-status-member">✓ Eres Miembro</span>`;
                }
                if (group.requestStatus === "Pending") {
                    return `<span class="badge-status badge-status-requested">⌛ Solicitud Pendiente</span>`;
                }
                return `<button class="btn-neon btn-join-group" data-id="${group.id}">Solicitar Unión</button>`;
            };

            // Manejar solicitud de unión por AJAX
            const handleJoinRequest = async (groupId, buttonElement) => {
                if (buttonElement.disabled) return;

                // Deshabilitar y mostrar estado intermedio
                buttonElement.disabled = true;
                buttonElement.textContent = "Enviando...";
                buttonElement.style.opacity = "0.7";

                try {
                    const response = await fetch(`/Group/JoinRequest?groupId=${groupId}`, {
                        method: "POST",
                        headers: {
                            "RequestVerificationToken": getAntiForgeryToken()
                        }
                    });

                    if (response.status === 409) {
                        alert("Ya has enviado una solicitud para este grupo.");
                        setButtonStateRequested(buttonElement);
                        return;
                    }

                    if (!response.ok) {
                        const errorMsg = await response.text();
                        throw new Error(errorMsg || "Error al procesar la solicitud.");
                    }

                    // Éxito: cambiar botón por badge solicitado
                    setButtonStateRequested(buttonElement);

                } catch (error) {
                    console.error("Error al enviar solicitud:", error);
                    alert(error.message || "Error al solicitar unión al grupo.");
                    buttonElement.disabled = false;
                    buttonElement.textContent = "Solicitar Unión";
                    buttonElement.style.opacity = "1";
                }
            };

            const setButtonStateRequested = (buttonElement) => {
                const parent = buttonElement.parentElement;
                parent.innerHTML = `<span class="badge-status badge-status-requested">⌛ Solicitud Pendiente</span>`;
            };

            // Anti forgery token helper
            const getAntiForgeryToken = () => {
                // Si hay un form en la página con input de validación, lo saca de ahí. Si no, devuelve vacío.
                const tokenInput = document.querySelector('input[name="__RequestVerificationToken"]');
                return tokenInput ? tokenInput.value : "";
            };

            // Buscar en tiempo real con debounce (300ms)
            searchInput.addEventListener("input", () => {
                clearTimeout(searchTimeout);
                searchTimeout = setTimeout(() => {
                    currentSearch = searchInput.value;
                    skip = 0;
                    hasMore = true;
                    loadGroups(false);
                }, 300);
            });

            // Cargar más al hacer clic en el botón
            btnLoadMore.addEventListener("click", () => {
                if (hasMore && !isLoading) {
                    loadGroups(true);
                }
            });

            // Scroll infinito opcional
            const handleScroll = () => {
                if (!hasMore || isLoading) return;
                
                // Si el scroll está cerca del final, cargar más automáticamente
                const mainContent = document.querySelector(".app-content");
                if (mainContent) {
                    const threshold = 100; // píxeles antes del final
                    const position = mainContent.scrollHeight - mainContent.scrollTop - mainContent.clientHeight;
                    
                    if (position <= threshold) {
                        loadGroups(true);
                    }
                }
            };
            
            const mainContent = document.querySelector(".app-content");
            if (mainContent) {
                mainContent.addEventListener("scroll", handleScroll);
            }

            // Escapar HTML para evitar XSS
            const escapeHtml = (unsafe) => {
                if (!unsafe) return "";
                return unsafe
                    .replace(/&/g, "&amp;")
                    .replace(/</g, "&lt;")
                    .replace(/>/g, "&gt;")
                    .replace(/"/g, "&quot;")
                    .replace(/'/g, "&#039;");
            };

            // Carga inicial de grupos
            loadGroups(false);
        });
    </script>
}
