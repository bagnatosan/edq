@{
    ViewData["Title"] = "Crear Grupo";
}

@Html.AntiForgeryToken()

<!-- Navegación y Encabezado -->
<div class="dashboard-header-nav" style="display: flex; align-items: center; gap: 12px; margin-bottom: 20px;">
    <a href="/Group/Explore" class="btn-back-arrow" style="color: var(--text-primary); text-decoration: none; display: flex; align-items: center; justify-content: center; width: 36px; height: 36px; border-radius: 50%; background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1); transition: background-color 0.2s;">
        <svg viewBox="0 0 24 24" width="20" height="20" stroke="currentColor" stroke-width="2.5" fill="none" stroke-linecap="round" stroke-linejoin="round">
            <line x1="19" y1="12" x2="5" y2="12"></line>
            <polyline points="12 19 5 12 12 5"></polyline>
        </svg>
    </a>
    <h1 class="hero-title" style="font-size: 20px; margin: 0; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; flex: 1;">Crear Nuevo Grupo</h1>
</div>

<!-- Sección: Crear Grupo -->
<div class="card active-neon" style="margin-bottom: 20px;">
    <div class="card-header-flex">
        <h2 class="card-title" style="color: var(--neon-green);">Detalles del Grupo</h2>
        <span class="card-subtitle-badge" style="color: var(--neon-green);">NUEVO</span>
    </div>
    
    <form id="createGroupForm" onsubmit="return false;" style="display: flex; flex-direction: column; gap: 16px;">
        <div class="form-group" style="margin-bottom: 0;">
            <label class="form-label">Nombre del Grupo</label>
            <input type="text" id="groupName" class="form-control-neon" placeholder="Ej. Fútbol F5 Club" maxlength="50" required style="padding: 12px 14px; font-size: 14px;" autocomplete="off" />
        </div>

        <button type="submit" id="btnCreateGroup" class="btn-neon" style="margin-top: 10px; width: 100%; justify-content: center;">
            <span class="btn-text">➕ Crear Grupo</span>
        </button>
    </form>
</div>

@section Scripts {
    <script src="~/js/create-group.js" asp-append-version="true"></script>
}
