@{
    ViewData["Title"] = "Dashboard de Grupo";
}

@Html.AntiForgeryToken()

<input type="hidden" id="groupIdInput" value="@ViewBag.GroupId" />

<!-- Navegación y Encabezado del Dashboard -->
<div class="dashboard-header-nav" style="display: flex; align-items: center; gap: 12px; margin-bottom: 20px;">
    <a href="/Group/Explore" class="btn-back-arrow" style="color: var(--text-primary); text-decoration: none; display: flex; align-items: center; justify-content: center; width: 36px; height: 36px; border-radius: 50%; background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1); transition: background-color 0.2s;">
        <svg viewBox="0 0 24 24" width="20" height="20" stroke="currentColor" stroke-width="2.5" fill="none" stroke-linecap="round" stroke-linejoin="round">
            <line x1="19" y1="12" x2="5" y2="12"></line>
            <polyline points="12 19 5 12 12 5"></polyline>
        </svg>
    </a>
    <h1 id="groupNameTitle" class="hero-title" style="font-size: 22px; margin: 0; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; flex: 1;">Cargando grupo...</h1>
</div>

<!-- Carrusel de Miembros -->
<div class="card" style="margin-bottom: 16px;">
    <div class="card-header-flex">
        <h2 class="card-title">Miembros</h2>
        <span id="membersCountBadge" class="card-subtitle-badge">0 JUGADORES</span>
    </div>
    <div id="membersCarousel" class="member-list-horizontal">
        <!-- Cargar dinámicamente por JS -->
    </div>
</div>

<!-- Banner Próximo Partido (Si hay alguno planificado) -->
<div id="upcomingMatchCard" class="card" style="display: none; border-color: var(--neon-green-glow); background: rgba(158, 255, 0, 0.01); margin-bottom: 16px;">
    <div class="card-header-flex">
        <h2 class="card-title" style="color: var(--neon-green);">Próximo Partido</h2>
        <span class="card-subtitle-badge" style="color: var(--neon-green);">CONVOCADO</span>
    </div>
    <div style="display: flex; flex-direction: column; gap: 10px;">
        <div id="matchTimeLabel" style="font-size: 15px; font-weight: 700; color: var(--text-primary);">
            Fecha del partido
        </div>
        
        <div class="teams-container" style="display: grid; grid-template-columns: 1fr 1fr; gap: 16px; background: rgba(255,255,255,0.02); padding: 10px; border-radius: var(--border-radius-md); border: 1px solid rgba(255,255,255,0.04);">
            <div style="border-right: 1px solid rgba(255,255,255,0.06); padding-right: 8px;">
                <div style="font-size: 11px; font-weight: 800; color: var(--neon-green); text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 4px;">Equipo A</div>
                <div id="teamAList" style="display: flex; flex-direction: column; gap: 4px; font-size: 13px; color: var(--text-secondary);">
                    <!-- Nombres -->
                </div>
            </div>
            <div style="padding-left: 8px;">
                <div style="font-size: 11px; font-weight: 800; color: var(--neon-green); text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 4px;">Equipo B</div>
                <div id="teamBList" style="display: flex; flex-direction: column; gap: 4px; font-size: 13px; color: var(--text-secondary);">
                    <!-- Nombres -->
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Acciones del Grupo -->
<div class="actions-container" style="display: flex; flex-direction: column; gap: 12px; margin-bottom: 20px;">
    <button id="btnCreateMatch" class="btn-neon" style="gap: 8px;">
        ⚽ Crear Nuevo Partido
    </button>
    <button id="btnAssignScores" class="btn-outline-neon" style="display: none; gap: 8px;">
        🛠️ Panel de Administración
    </button>
    <button id="btnMatchHistory" class="btn-outline-neon" style="gap: 8px;">
        📅 Historial de Partidos
    </button>
</div>

<!-- Panel de Administración (Solo para Creadores con Solicitudes Pendientes) -->
<div id="adminPanel" class="card" style="display: none; border-color: var(--neon-green-glow); margin-bottom: 16px;">
    <div class="card-header-flex">
        <h2 class="card-title" style="color: var(--neon-green);">Solicitudes Pendientes</h2>
        <span id="requestsCountBadge" class="card-subtitle-badge" style="color: var(--neon-green);">0 PENDIENTES</span>
    </div>
    <div id="requestsList" class="requests-list" style="display: flex; flex-direction: column; gap: 12px;">
        <!-- Cargar dinámicamente por JS -->
    </div>
</div>

<!-- Ranking del Grupo -->
<div class="card active-neon">
    <div class="card-header-flex">
        <h2 class="card-title">Ranking del Grupo</h2>
        <span class="card-subtitle-badge">WINRATE</span>
    </div>
    <div id="rankingList" style="display: flex; flex-direction: column; gap: 12px;">
        <!-- Cargar dinámicamente por JS -->
    </div>
</div>

@section Scripts {
    <script src="~/js/dashboard.js" asp-append-version="true"></script>
}
