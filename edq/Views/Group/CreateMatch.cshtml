@{
    ViewData["Title"] = "Crear Nuevo Partido";
}

@section Styles {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css">
}

@Html.AntiForgeryToken()

<input type="hidden" id="groupIdInput" value="@ViewBag.GroupId" />

<!-- Navegación y Encabezado -->
<div class="dashboard-header-nav" style="display: flex; align-items: center; gap: 12px; margin-bottom: 20px;">
    <a href="/Group/Dashboard?groupId=@ViewBag.GroupId" class="btn-back-arrow" style="color: var(--text-primary); text-decoration: none; display: flex; align-items: center; justify-content: center; width: 36px; height: 36px; border-radius: 50%; background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1); transition: background-color 0.2s;">
        <svg viewBox="0 0 24 24" width="20" height="20" stroke="currentColor" stroke-width="2.5" fill="none" stroke-linecap="round" stroke-linejoin="round">
            <line x1="19" y1="12" x2="5" y2="12"></line>
            <polyline points="12 19 5 12 12 5"></polyline>
        </svg>
    </a>
    <h1 id="groupNameTitle" class="hero-title" style="font-size: 20px; margin: 0; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; flex: 1;">Crear Partido</h1>
</div>

<!-- Formulario de Configuración del Partido -->
<div class="card" style="border-color: rgba(255, 255, 255, 0.05);">
    <div style="display: flex; flex-direction: column; gap: 20px;">
        
        <!-- Campo Fecha y Hora -->
        <div>
            <label style="font-size: 13px; font-weight: 700; color: var(--text-secondary); text-transform: uppercase; letter-spacing: 0.5px; display: block; margin-bottom: 8px;">Fecha del Encuentro</label>
            <input type="datetime-local" id="matchDateTime" style="display: none;" />
        </div>

        <!-- Campo Convocados -->
        <div>
            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 12px;">
                <div>
                    <label style="font-size: 13px; font-weight: 700; color: var(--text-secondary); text-transform: uppercase; letter-spacing: 0.5px; display: block;">Convocados Iniciales</label>
                    <span id="selectedPlayersCount" style="font-size: 11px; color: var(--text-muted); display: block; margin-top: 2px;">Seleccionados: 0</span>
                </div>
                <div style="display: flex; gap: 8px;">
                    <button type="button" id="btnSelectAll" style="background: none; border: none; color: var(--neon-green); font-size: 12px; font-weight: 700; cursor: pointer; padding: 0;">Todos</button>
                    <span style="color: var(--text-muted); font-size: 12px;">|</span>
                    <button type="button" id="btnClearAll" style="background: none; border: none; color: var(--text-secondary); font-size: 12px; font-weight: 700; cursor: pointer; padding: 0;">Ninguno</button>
                </div>
            </div>
            
            <div id="playersCheckboxGrid" class="player-checkbox-grid" style="max-height: 280px; overflow-y: auto; padding-right: 4px; gap: 12px 16px;">
                <!-- Carga dinámica por AJAX -->
                <div class="loading-spinner" style="display: flex; justify-content: center; padding: 20px 0; color: var(--text-muted); grid-column: span 2;">Cargando jugadores...</div>
            </div>
        </div>

        <!-- Botón de Envío -->
        <div style="margin-top: 10px;">
            <button type="button" id="btnBalanceAndCreate" class="btn-neon" style="width: 100%; justify-content: center; gap: 8px;">
                ⚖️ Balancear y Crear Partido
            </button>
        </div>

    </div>
</div>

<!-- Modal de Carga de Emparejamiento Estilizado -->
<div id="matchmakingLoadingModal" style="display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(9, 10, 13, 0.85); backdrop-filter: blur(8px); -webkit-backdrop-filter: blur(8px); z-index: 10000; align-items: center; justify-content: center; opacity: 0; transition: opacity 0.25s ease-out;">
    <div id="matchmakingLoadingCard" class="card" style="max-width: 320px; width: 90%; border-color: rgba(255, 255, 255, 0.05); background: rgba(26, 29, 36, 0.95); box-shadow: 0 8px 32px rgba(0, 0, 0, 0.6); text-align: center; display: flex; flex-direction: column; gap: 16px; padding: 28px; transform: scale(0.9); transition: transform 0.25s cubic-bezier(0.34, 1.56, 0.64, 1), border-color 0.3s ease, box-shadow 0.3s ease;">
        <!-- Icono de Progreso Circular -->
        <div style="position: relative; width: 80px; height: 80px; margin: 0 auto;">
            <svg viewBox="0 0 36 36" style="width: 80px; height: 80px; transform: rotate(-90deg);">
                <path d="M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831" fill="none" stroke="rgba(255, 255, 255, 0.05)" stroke-width="3" />
                <path id="loadingProgressPath" d="M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831" fill="none" stroke="var(--neon-green-solid)" stroke-width="3" stroke-dasharray="0, 100" stroke-linecap="round" style="transition: stroke-dasharray 0.1s linear;" />
            </svg>
            <div id="loadingIconContainer" style="position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); font-size: 28px; transition: transform 0.3s ease;">⚖️</div>
        </div>
        <h3 id="loadingTitle" style="font-size: 18px; font-weight: 700; color: var(--text-primary); margin: 0;">Balanceando Equipos</h3>
        <p id="loadingSubtitle" style="font-size: 13px; color: var(--text-secondary); line-height: 1.5; margin: 0;">Ejecutando algoritmo de emparejamiento...</p>
        <span id="loadingPercent" style="font-size: 12px; font-weight: 700; color: var(--neon-green); margin-top: -4px;">0%</span>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
    <script src="https://npmcdn.com/flatpickr/dist/l10n/es.js"></script>
    <script src="~/js/create-match.js" asp-append-version="true"></script>
}
