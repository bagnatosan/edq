@{
    ViewData["Title"] = "Chat y Encuestas";
}

@Html.AntiForgeryToken()

<style>
    .app-content {
        overflow: hidden !important;
        padding: 10px 0 0 0 !important;
        display: flex !important;
        flex-direction: column !important;
    }
    .chat-dropdown-item {
        width: 100%;
        text-align: left;
        background: none;
        border: none;
        padding: 12px 16px;
        color: var(--text-primary);
        font-size: 14px;
        font-weight: 600;
        cursor: pointer;
        display: flex;
        align-items: center;
        gap: 8px;
        transition: background-color 0.2s, color 0.2s;
    }
    .chat-dropdown-item:hover {
        background-color: rgba(158, 255, 0, 0.1) !important;
        color: var(--neon-green) !important;
    }
</style>

<input type="hidden" id="groupIdInput" value="@ViewBag.GroupId" />
<input type="hidden" id="currentUserIdInput" value="@User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value" />

<!-- Header del Chat -->
<div class="chat-header-nav" style="display: flex; align-items: center; gap: 12px; margin-bottom: 20px; border-bottom: 1px solid rgba(255,255,255,0.05); padding-bottom: 12px; padding-left: 16px; padding-right: 16px;">
    <a href="/Group/Chat" class="btn-back-arrow" style="color: var(--text-primary); text-decoration: none; display: flex; align-items: center; justify-content: center; width: 36px; height: 36px; border-radius: 50%; background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1); transition: background-color 0.2s;">
        <svg viewBox="0 0 24 24" width="20" height="20" stroke="currentColor" stroke-width="2.5" fill="none" stroke-linecap="round" stroke-linejoin="round">
            <line x1="19" y1="12" x2="5" y2="12"></line>
            <polyline points="12 19 5 12 12 5"></polyline>
        </svg>
    </a>
    <h1 class="hero-title" style="font-size: 20px; margin: 0; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; flex: 1;">@ViewBag.GroupName</h1>
</div>

<!-- Contenedor Principal del Chat -->
<div class="chat-container-layout" style="display: flex; flex-direction: column; flex: 1; height: auto !important; position: relative; overflow: hidden;">
    
    <!-- Mensajes de Chat (con padding-bottom para que los mensajes no queden detrás del panel de entrada) -->
    <div id="chatMessages" class="chat-messages-scroll" style="flex: 1; overflow-y: auto; padding: 10px 16px 180px 16px; display: flex; flex-direction: column; gap: 12px; scroll-behavior: smooth;">
        <div class="chat-loading-container" style="display: flex; flex-direction: column; align-items: center; justify-content: center; height: 100%; min-height: 200px; gap: 12px; flex: 1;">
            <div style="width: 40px; height: 40px; border: 3px solid rgba(158, 255, 0, 0.15); border-top-color: var(--neon-green-solid); border-radius: 50%; animation: spin 0.8s linear infinite;"></div>
            <span style="font-size: 13px; color: var(--text-secondary); font-weight: 500;">Cargando mensajes...</span>
        </div>
    </div>

    <!-- Área de entrada de texto fija al fondo con cristal/transparencia y bordes -->
    <div class="chat-input-area" style="position: fixed; bottom: 86px; left: 16px; right: 16px; background: rgba(10, 10, 10, 0.7); backdrop-filter: blur(16px); -webkit-backdrop-filter: blur(16px); border: 1px solid rgba(255, 255, 255, 0.08); border-radius: 20px; padding: 8px 12px; display: flex; gap: 8px; align-items: center; z-index: 10; box-shadow: 0 -4px 20px rgba(0, 0, 0, 0.3);">
        <!-- Botón + con Menú Desplegable -->
        <div style="position: relative; display: inline-block; flex-shrink: 0;">
            <button id="btnChatActions" class="btn-outline-neon" style="width: 46px; height: 46px; border-radius: 50%; padding: 0; display: flex; align-items: center; justify-content: center; font-size: 20px; font-weight: 700; line-height: 1;" aria-label="Acciones de chat" type="button">
                ＋
            </button>
            <!-- Menú Desplegable -->
            <div id="chatActionsDropdown" class="glass-panel" style="display: none; position: absolute; bottom: 56px; left: 0; min-width: 170px; border: 1px solid rgba(255,255,255,0.1); border-radius: var(--border-radius-md); background: rgba(18, 20, 26, 0.95); backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px); box-shadow: 0 8px 32px rgba(0,0,0,0.5); z-index: 100; padding: 6px 0;">
                <button type="button" id="btnCreatePollFromDropdown" class="chat-dropdown-item">
                    📊 Crear encuesta
                </button>
            </div>
        </div>

        <input type="text" id="chatMessageInput" placeholder="Escribe aquí..." class="form-control-neon" style="flex: 1; margin-bottom: 0; padding: 12px 16px; font-size: 14px;" />
        
        <button id="btnSendMessage" class="btn-neon" style="width: 46px; height: 46px; border-radius: 50%; padding: 0; display: flex; align-items: center; justify-content: center; flex-shrink: 0;" aria-label="Enviar mensaje">
            <svg viewBox="0 0 24 24" width="20" height="20" stroke="currentColor" stroke-width="2.5" fill="none" stroke-linecap="round" stroke-linejoin="round" style="transform: rotate(45deg); margin-left: -2px;">
                <line x1="22" y1="2" x2="11" y2="13"></line>
                <polygon points="22 2 15 22 11 13 2 9 22 2"></polygon>
            </svg>
        </button>
    </div>
</div>

<!-- Modal para Crear Nueva Encuesta -->
<div id="createPollModal" class="modal-backdrop" style="position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.8); backdrop-filter: blur(8px); z-index: 30; display: none; align-items: center; justify-content: center; opacity: 0; transition: opacity 0.25s ease;">
    <div id="createPollCard" class="card" style="width: 90%; max-width: 400px; transform: scale(0.9); transition: transform 0.25s ease; border-color: rgba(255,255,255,0.08);">
        <h2 class="card-title" style="margin-bottom: 16px; color: var(--neon-green);">Crear Encuesta</h2>
        
        <form id="createPollForm">
            <div style="margin-bottom: 12px;">
                <label class="form-label" style="font-size: 11px;">Pregunta</label>
                <input type="text" id="pollQuestion" placeholder="¿Quién asiste al partido?" class="form-control-neon" required />
            </div>

            <div style="margin-bottom: 16px;">
                <label class="form-label" style="font-size: 11px; display: flex; justify-content: space-between;">
                    <span>Opciones de Respuesta</span>
                    <button type="button" id="btnAddPollOption" style="background: none; border: none; color: var(--neon-green); font-weight: 700; cursor: pointer; padding: 0;">+ Agregar</button>
                </label>
                <div id="pollOptionsContainer" style="display: flex; flex-direction: column; gap: 8px;">
                    <input type="text" class="form-control-neon poll-option-input" placeholder="Opción 1" required />
                    <input type="text" class="form-control-neon poll-option-input" placeholder="Opción 2" required />
                </div>
            </div>

            <div style="margin-bottom: 20px;">
                <label class="form-label" style="font-size: 11px;">Duración (Horas)</label>
                <select id="pollDuration" class="form-control-neon" style="padding: 10px;">
                    <option value="60">1 Hora</option>
                    <option value="720">12 Horas</option>
                    <option value="1440" selected>24 Horas</option>
                    <option value="10080">7 Días</option>
                </select>
            </div>

            <div style="display: flex; gap: 10px;">
                <button type="button" id="btnCancelPoll" class="btn-outline-neon" style="flex: 1; justify-content: center; padding: 10px;">Cancelar</button>
                <button type="submit" class="btn-neon" style="flex: 1; justify-content: center; padding: 10px;">Lanzar</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <!-- SignalR Client Library from CDN -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.7/signalr.min.js"></script>
    <script src="~/js/chat.js" asp-append-version="true"></script>
}
