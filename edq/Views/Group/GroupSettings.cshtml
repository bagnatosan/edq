@{
    ViewData["Title"] = "Cambiar Nombre del Grupo";
}

@Html.AntiForgeryToken()

<input type="hidden" id="groupIdInput" value="@ViewBag.GroupId" />

<!-- Navegación y Encabezado -->
<div class="dashboard-header-nav" style="display: flex; align-items: center; gap: 12px; margin-bottom: 20px;">
    <a href="/Group/AdminPanel?groupId=@ViewBag.GroupId" class="btn-back-arrow" style="color: var(--text-primary); text-decoration: none; display: flex; align-items: center; justify-content: center; width: 36px; height: 36px; border-radius: 50%; background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1); transition: background-color 0.2s;">
        <svg viewBox="0 0 24 24" width="20" height="20" stroke="currentColor" stroke-width="2.5" fill="none" stroke-linecap="round" stroke-linejoin="round">
            <line x1="19" y1="12" x2="5" y2="12"></line>
            <polyline points="12 19 5 12 12 5"></polyline>
        </svg>
    </a>
    <h1 id="groupNameTitle" class="hero-title" style="font-size: 20px; margin: 0; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; flex: 1;">Ajustes de Grupo</h1>
</div>

<!-- Tarjeta de Configuración del Nombre -->
<div class="card" style="border-color: rgba(255, 255, 255, 0.05); margin-bottom: 20px;">
    <div class="card-header-flex">
        <h2 class="card-title">Datos del Grupo</h2>
        <span class="card-subtitle-badge">GENERAL</span>
    </div>
    <div style="display: flex; flex-direction: column; gap: 18px;">
        <div class="form-group" style="margin-bottom: 0;">
            <label class="form-label">Nombre del Grupo</label>
            <input type="text" id="groupNameInput" class="form-control-neon" placeholder="Cargando..." maxlength="50" style="padding: 12px 14px; font-size: 14px;" />
        </div>
    </div>
</div>

<!-- Botón Guardar Cambios (Real Backend Action) -->
<div>
    <button type="button" id="btnSaveSettings" class="btn-neon" style="width: 100%; justify-content: center;">
        <span class="btn-text">💾 Guardar Nombre</span>
    </button>
</div>

@section Scripts {
    <script src="~/js/group-settings.js" asp-append-version="true"></script>
}
